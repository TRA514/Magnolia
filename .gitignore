.DS_Store
node_modules/
venv/
.env*
__pycache__/
*.log

# Keep folder structure but ignore content files in datasets
# This allows team members to clone the skeleton without your specific data

# Product folder: keep structure and templates, ignore everything else
datasets/product/*
!datasets/product/.gitkeep
!datasets/product/*/
!datasets/product/*/.gitkeep
datasets/product/*/*
!datasets/product/templates/
!datasets/product/*/*/.gitkeep

# Research folder: keep structure and templates, ignore everything else
datasets/research/*
!datasets/research/.gitkeep
!datasets/research/*/
!datasets/research/*/.gitkeep
datasets/research/*/*
!datasets/research/templates/
!datasets/research/*/*/.gitkeep

# Strategy folder: keep structure and templates, ignore everything else
datasets/strategy/*
!datasets/strategy/.gitkeep
!datasets/strategy/*/
!datasets/strategy/*/.gitkeep
datasets/strategy/*/*
!datasets/strategy/templates/
!datasets/strategy/*/*/.gitkeep

# Meetings folder: keep structure, ignore all files
datasets/meetings/*
!datasets/meetings/.gitkeep
!datasets/meetings/*/
!datasets/meetings/*/.gitkeep
datasets/meetings/*/*
!datasets/meetings/*/*/.gitkeep

# Tasks folder: keep queue structure, ignore all task content
datasets/tasks/*
!datasets/tasks/.gitkeep
!datasets/tasks/*/
!datasets/tasks/*/.gitkeep
datasets/tasks/*/*
!datasets/tasks/*/*/.gitkeep

# Cron folder: keep structure, ignore job definitions and outputs
datasets/cron/*
!datasets/cron/.gitkeep
!datasets/cron/*/
!datasets/cron/*/.gitkeep
datasets/cron/*/*
!datasets/cron/*/*/.gitkeep

# People folder: keep structure, ignore people data (e.g. email cache)
datasets/people/*
!datasets/people/.gitkeep

# Recruiting folder: keep structure and templates, ignore candidate data
datasets/recruiting/*
!datasets/recruiting/.gitkeep
!datasets/recruiting/*/
!datasets/recruiting/*/.gitkeep
datasets/recruiting/*/*
!datasets/recruiting/templates/
!datasets/recruiting/*/*/.gitkeep

# Evals folder: keep category structure, ignore eval runs and golden datasets
datasets/evals/*
!datasets/evals/.gitkeep
!datasets/evals/*/
!datasets/evals/*/.gitkeep
datasets/evals/*/*
!datasets/evals/*/*/.gitkeep

# Reference folder: ignore personal reference content
datasets/reference/*
!datasets/reference/.gitkeep

# Per-person profile is gitignored; the .example template is tracked.
/profile/

# Docs folder: exclude scratch/implementation notes, but track design plans
# and the durable reference layer (invariants, conventions, architecture).
docs/*
!docs/plans/
!docs/reference/
!docs/INSTALL.md
!docs/INSTALL-macos.md
!docs/INSTALL-windows.md
